#!/usr/bin/env python3
"""Entry point shim for PATCHIT MCP Server.

Can be run directly:
  ./patchit-mcp-server

Or via Python:
  python3 patchit-mcp-server
"""
import os
import sys

# Set PATCHIT_ROOT to the directory containing this script
_HERE = os.path.dirname(os.path.abspath(__file__))
if "PATCHIT_ROOT" not in os.environ:
    os.environ["PATCHIT_ROOT"] = _HERE

# Add project to path
if _HERE not in sys.path:
    sys.path.insert(0, _HERE)

from patchit.mcp.server import main
main()
